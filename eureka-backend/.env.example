# App Settings
APP_NAME=EUREKA
DEBUG=False

# Ollama Settings
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT=300

# Database Settings
DATABASE_URL=postgresql://eureka_user:eureka_password@localhost:5432/eureka_db

# Redis Settings
REDIS_URL=redis://localhost:6379

# JWT Settings
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Settings
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173","https://eureka.io"]
